# Normalizar finales de línea
* text=auto eol=lf

# Archivos de código
*.ts text
*.js text
*.json text
*.md text
*.yml text
*.yaml text
*.sh text

# Scripts de Windows
*.bat text eol=crlf
*.cmd text eol=crlf

# Binarios
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary