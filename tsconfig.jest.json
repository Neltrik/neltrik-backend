{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "CommonJS",
        "moduleResolution": "Node",
        "types": ["node", "jest"],
        "isolatedModules": false,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": false
    },

    "include": ["src/**/*.test.ts"],
    "exclude": ["node_modules", "dist", "scripts"]
}
