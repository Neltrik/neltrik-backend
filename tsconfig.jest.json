{
    "extends": "./tsconfig.app.json",
    "compilerOptions": {
        "composite": true,
        "module": "CommonJS",
        "moduleResolution": "Node",
        "types": ["node", "jest"],
        "isolatedModules": false,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": false
    },

    "include": ["src/**/*.ts", "src/**/test-doubles/**/*"],
    "exclude": ["node_modules", "dist", "scripts"]
}
